# ============================================
# DiaBeta Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control!

# ============================================
# Application Settings
# ============================================
NODE_ENV=production

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_DB=diabeta
POSTGRES_USER=diabeta
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# JWT Authentication
# ============================================
# IMPORTANT: Use a strong secret (min 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-long-change-in-production

# ============================================
# Telegram Bot
# ============================================
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_USERNAME=your_bot_username

# ============================================
# MinIO / S3 Storage (Optional)
# ============================================
# For file uploads (photos, reports, etc.)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_minio_secret_in_production
MINIO_BUCKET=diabeta

# If using AWS S3 instead of MinIO:
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_ACCESS_KEY=your-aws-access-key
# MINIO_SECRET_KEY=your-aws-secret-key
# MINIO_BUCKET=your-bucket-name

# ============================================
# YooKassa Payment Gateway (Optional)
# ============================================
# For subscription payments
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# ============================================
# Backend API
# ============================================
BACKEND_PORT=3001

# ============================================
# Nginx
# ============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# SSL/TLS Certificates (Production Only)
# ============================================
# Place certificates in ./ssl directory:
# - fullchain.pem
# - privkey.pem
# Uncomment HTTPS section in nginx.conf when ready

# ============================================
# Additional Settings
# ============================================
# Timezone for logs and timestamps
TZ=Europe/Moscow

# Log level (debug, info, warn, error)
LOG_LEVEL=info
